# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=

# Telegram channel/group username (without @) or numeric ID
TELEGRAM_CHANNEL=

# Manual Date (YYYY-MM-DD), leave blank or comment out for Today
# TARGET_DATE=2024-03-14

# Optional: scan interval in minutes (0 = run once)
SCAN_INTERVAL=0
