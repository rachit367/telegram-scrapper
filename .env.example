# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=

# Telegram channel/group username (without @) or numeric ID
TELEGRAM_CHANNEL=

# Process Mode: "llm" (use AI extraction) or "raw" (just save text to raw_messages.md)
PROCESS_MODE=llm

# AI Provider: "openai", "gemini", or "openrouter"
AI_PROVIDER=openrouter

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=

# OpenRouter Configuration (required if AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/hunter-alpha

# Optional: scan interval in minutes (0 = run once)
SCAN_INTERVAL=0
